## Copy this file to .env and fill in real values. Do not commit .env.

# Core
PROJECT_NAME=FastAPI Backend Boilerplate
ENVIRONMENT=local
LOG_LEVEL=INFO
# Next.js local dev server runs on port 3000.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# Database (use postgresql:// scheme for asyncpg — NOT postgresql+asyncpg://)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# LLM — set one or both. OPENAI_API_KEY takes priority over OpenRouter when both are set.
# OpenAI: used for job extraction and resume tailoring agent (model: gpt-5.4-mini)
OPENAI_API_KEY=sk-...
# OpenRouter: fallback when OPENAI_API_KEY is not set (model: google/gemma-3-27b-it:free)
#OPENROUTER_API_KEY=

# Apify: required for job opening URL crawling (website-content-crawler actor)
# Get a token at https://console.apify.com/account/integrations
APIFY_API_TOKEN=apify_api_...

# LangSmith / LangChain (optional): enables tracing for LangChain paths (resume agent, email agent,
# and job opening extraction). Project name is set in code (ETB_Project). Get a key from LangSmith.
#LANGCHAIN_API_KEY=

