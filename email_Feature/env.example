# Rename this file to .env and fill in your keys.
# Never commit the .env file to git.

# ── LLM Provider ──────────────────────────────────────────────
# Choose one: anthropic | groq | ollama
LLM_PROVIDER=anthropic

# Optional: override the default model for the chosen provider
# Anthropic default : claude-3-5-sonnet-20241022
# Groq default      : llama-3.3-70b-versatile
# Ollama default    : llama3.2
# LLM_MODEL=

# ── API Keys ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here   # required if LLM_PROVIDER=anthropic
GROQ_API_KEY=your_groq_api_key_here             # required if LLM_PROVIDER=groq
# OLLAMA_BASE_URL=http://localhost:11434         # optional, ollama only

# ── Apollo ────────────────────────────────────────────────────
APOLLO_API_KEY=your_apollo_api_key_here         # optional — graph handles missing key

# ── Resend (email sending) ─────────────────────────────────────
RESEND_API_KEY=your_resend_api_key_here         # from resend.com — free tier 3,000 emails/month
RESEND_FROM_EMAIL=onboarding@resend.dev         # use this for testing without a verified domain
# RESEND_FROM_EMAIL=you@yourdomain.com          # use your own domain once verified in Resend
